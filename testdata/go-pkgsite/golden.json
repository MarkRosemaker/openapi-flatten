{
  "openapi": "3.0.3",
  "info": {
    "title": "Go Pkgsite API",
    "description": "API for accessing information about Go packages and modules on pkg.go.dev.",
    "version": "v0.1.0"
  },
  "servers": [
    {
      "url": "https://pkg.go.dev/v1beta"
    }
  ],
  "paths": {
    "/imported-by/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path"
        },
        {
          "$ref": "#/components/parameters/module"
        },
        {
          "$ref": "#/components/parameters/version"
        },
        {
          "$ref": "#/components/parameters/limit"
        },
        {
          "$ref": "#/components/parameters/token"
        },
        {
          "$ref": "#/components/parameters/filter"
        }
      ],
      "get": {
        "summary": "Paths of packages importing the package at {path},\nnot including packages in the same module.\nFiltering is applied to the list of paths in the response.\nOnly paths that match the filter query parameter are returned.\nWithin a filter, the variable `path` is set to the import path.",
        "operationId": "getImported-by",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetImportedByOkResponse"
          }
        }
      }
    },
    "/module/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path2"
        },
        {
          "$ref": "#/components/parameters/version2"
        },
        {
          "$ref": "#/components/parameters/licenses"
        },
        {
          "$ref": "#/components/parameters/readme"
        }
      ],
      "get": {
        "summary": "Information about the module at {path}.",
        "operationId": "getModule",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetModuleOkResponse"
          }
        }
      }
    },
    "/package/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path3"
        },
        {
          "$ref": "#/components/parameters/module2"
        },
        {
          "$ref": "#/components/parameters/version3"
        },
        {
          "$ref": "#/components/parameters/goos"
        },
        {
          "$ref": "#/components/parameters/goarch"
        },
        {
          "$ref": "#/components/parameters/doc"
        },
        {
          "$ref": "#/components/parameters/examples"
        },
        {
          "$ref": "#/components/parameters/imports"
        },
        {
          "$ref": "#/components/parameters/licenses2"
        }
      ],
      "get": {
        "summary": "Information about the package at {path}.",
        "operationId": "getPackage",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetPackageOkResponse"
          }
        }
      }
    },
    "/packages/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path4"
        },
        {
          "$ref": "#/components/parameters/version4"
        },
        {
          "$ref": "#/components/parameters/limit2"
        },
        {
          "$ref": "#/components/parameters/token2"
        },
        {
          "$ref": "#/components/parameters/filter2"
        }
      ],
      "get": {
        "summary": "Information about packages of the module at {path}.\nFiltering is applied to the list of packages in the response.\nOnly packages that match the filter query parameter are returned.",
        "operationId": "getPackages",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetPackagesOkResponse"
          }
        }
      }
    },
    "/search": {
      "parameters": [
        {
          "$ref": "#/components/parameters/q"
        },
        {
          "$ref": "#/components/parameters/symbol"
        },
        {
          "$ref": "#/components/parameters/limit3"
        },
        {
          "$ref": "#/components/parameters/token3"
        },
        {
          "$ref": "#/components/parameters/filter3"
        }
      ],
      "get": {
        "summary": "Search results. Only results that match the filter query parameter are returned.",
        "operationId": "getSearch",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetSearchOkResponse"
          }
        }
      }
    },
    "/symbols/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path5"
        },
        {
          "$ref": "#/components/parameters/module3"
        },
        {
          "$ref": "#/components/parameters/version5"
        },
        {
          "$ref": "#/components/parameters/goos2"
        },
        {
          "$ref": "#/components/parameters/goarch2"
        },
        {
          "$ref": "#/components/parameters/limit4"
        },
        {
          "$ref": "#/components/parameters/token4"
        },
        {
          "$ref": "#/components/parameters/filter4"
        }
      ],
      "get": {
        "summary": "List of symbols for the package at {path}.\nFiltering is applied to the list of symbols in the response.\nOnly symbols that match the filter query parameter are returned.",
        "operationId": "getSymbols",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetSymbolsOkResponse"
          }
        }
      }
    },
    "/versions/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path6"
        },
        {
          "$ref": "#/components/parameters/limit5"
        },
        {
          "$ref": "#/components/parameters/token5"
        },
        {
          "$ref": "#/components/parameters/filter5"
        }
      ],
      "get": {
        "summary": "Versions of the module at {path}.\nIf there are tagged versions, they are returned.\nOtherwise, the 10 most recent pseudo-versions are returned.\nThe versions are in descending order.\nOnly results that match the filter query parameter are returned.",
        "operationId": "getVersions",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetVersionsOkResponse"
          }
        }
      }
    },
    "/vulns/{path}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/path7"
        },
        {
          "$ref": "#/components/parameters/module4"
        },
        {
          "$ref": "#/components/parameters/version6"
        },
        {
          "$ref": "#/components/parameters/limit6"
        },
        {
          "$ref": "#/components/parameters/token6"
        },
        {
          "$ref": "#/components/parameters/filter6"
        }
      ],
      "get": {
        "summary": "Vulnerabilities of the module or package at {path}, from\nthe Go vulnerability database (https://vuln.go.dev).\nOnly results that match the filter query parameter are returned.",
        "operationId": "getVulns",
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetVulnsOkResponse"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Candidate": {
        "type": "object",
        "properties": {
          "modulePath": {
            "type": "string"
          },
          "packagePath": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "candidates": {
            "$ref": "#/components/schemas/ErrorCandidates"
          },
          "code": {
            "description": "HTTP status code",
            "type": "integer"
          },
          "err": {
            "$ref": "#/components/schemas/Error",
            "description": "Unexported field for internal tracking"
          },
          "fixes": {
            "description": "suggestions for how to fix",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          }
        }
      },
      "License": {
        "type": "object",
        "properties": {
          "contents": {
            "type": "string"
          },
          "filePath": {
            "type": "string"
          },
          "types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Module": {
        "type": "object",
        "properties": {
          "commitTime": {
            "description": "CommitTime is the timestamp returned by the module proxy's .info endpoint,\nrepresenting the time the version was created.",
            "type": "string",
            "format": "date-time"
          },
          "goModContents": {
            "type": "string"
          },
          "hasGoMod": {
            "type": "boolean"
          },
          "isLatest": {
            "type": "boolean"
          },
          "isRedistributable": {
            "type": "boolean"
          },
          "isStandardLibrary": {
            "type": "boolean"
          },
          "licenses": {
            "$ref": "#/components/schemas/ModuleLicenses"
          },
          "path": {
            "type": "string"
          },
          "readme": {
            "$ref": "#/components/schemas/Readme"
          },
          "repoUrl": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "ModuleVersion": {
        "type": "object",
        "properties": {
          "commitTime": {
            "type": "string",
            "format": "date-time"
          },
          "deprecated": {
            "type": "boolean"
          },
          "deprecationReason": {
            "type": "string"
          },
          "hasGoMod": {
            "description": "Whether the module has a go.mod file.",
            "type": "boolean"
          },
          "isRedistributable": {
            "description": "Whether the license allows distribution.",
            "type": "boolean"
          },
          "latestVersion": {
            "description": "latest unretracted version",
            "type": "string"
          },
          "modulePath": {
            "type": "string"
          },
          "retracted": {
            "type": "boolean"
          },
          "retractionReason": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "Package": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "string"
          },
          "goarch": {
            "type": "string",
            "example": "all"
          },
          "goos": {
            "type": "string",
            "example": "all"
          },
          "imports": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isLatest": {
            "type": "boolean",
            "example": true
          },
          "isStandardLibrary": {
            "type": "boolean",
            "example": false
          },
          "licenses": {
            "$ref": "#/components/schemas/PackageLicenses"
          },
          "modulePath": {
            "type": "string",
            "example": "github.com/google/go-cmp"
          },
          "version": {
            "type": "string",
            "example": "v0.7.0"
          },
          "path": {
            "type": "string",
            "example": "github.com/google/go-cmp/cmp"
          },
          "name": {
            "type": "string",
            "example": "cmp"
          },
          "synopsis": {
            "type": "string",
            "example": "Package cmp determines equality of values."
          },
          "isRedistributable": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "PackageImportedBy": {
        "type": "object",
        "properties": {
          "importedBy": {
            "$ref": "#/components/schemas/PaginatedResponse"
          },
          "modulePath": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "PackageInfo": {
        "type": "object",
        "properties": {
          "isRedistributable": {
            "description": "Whether the license allows distribution.",
            "type": "boolean"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "synopsis": {
            "type": "string"
          }
        }
      },
      "PackageSymbols": {
        "type": "object",
        "properties": {
          "modulePath": {
            "type": "string"
          },
          "symbols": {
            "$ref": "#/components/schemas/PaginatedResponse"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "PackagesResponse": {
        "type": "object",
        "properties": {
          "isStandardLibrary": {
            "type": "boolean"
          },
          "modulePath": {
            "type": "string"
          },
          "packages": {
            "$ref": "#/components/schemas/PaginatedResponse"
          },
          "version": {
            "type": "string"
          },
          "code": {
            "type": "integer",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "golang.org/x/time/rate is a package, not a module"
          },
          "fixes": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "retry the call with the containing module: \"golang.org/x/time\""
            }
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "items": {
            "$ref": "#/components/schemas/PaginatedResponseItems"
          },
          "nextPageToken": {
            "type": "string",
            "example": "c5806e999a87f632c2e6016f77dbf204"
          },
          "total": {
            "type": "integer",
            "example": 15
          }
        }
      },
      "Readme": {
        "type": "object",
        "properties": {
          "contents": {
            "type": "string"
          },
          "filepath": {
            "type": "string"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "modulePath": {
            "type": "string"
          },
          "packagePath": {
            "type": "string"
          },
          "synopsis": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "Symbol": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          },
          "synopsis": {
            "type": "string"
          }
        }
      },
      "Vulnerability": {
        "type": "object",
        "properties": {
          "details": {
            "type": "string"
          },
          "fixedVersion": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "ErrorCandidates": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Candidate"
        }
      },
      "ModuleLicenses": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/License"
        }
      },
      "PackageLicenses": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/License"
        }
      },
      "PaginatedResponseItems": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/PaginatedResponseItemsItem"
        }
      },
      "PaginatedResponseItemsItem": {
        "type": "object",
        "properties": {
          "modulePath": {
            "type": "string",
            "example": "golang.org/x/time"
          },
          "version": {
            "type": "string",
            "example": "v0.15.0"
          },
          "commitTime": {
            "type": "string",
            "format": "date-time",
            "example": "2026-02-11T19:14:29Z"
          },
          "isRedistributable": {
            "type": "boolean",
            "example": true
          },
          "hasGoMod": {
            "type": "boolean",
            "example": true
          },
          "latestVersion": {
            "type": "string",
            "example": "v0.15.0"
          },
          "deprecated": {
            "type": "boolean",
            "example": false
          },
          "deprecationReason": {
            "type": "string",
            "example": ""
          },
          "retracted": {
            "type": "boolean",
            "example": false
          },
          "retractionReason": {
            "type": "string",
            "example": ""
          }
        }
      }
    },
